{
  "name": "nuxt-live-cursors",
  "type": "module",
  "version": "0.3.1",
  "packageManager": "pnpm@10.32.1",
  "description": "Real-time live cursors for Nuxt - see other visitors on your site",
  "author": "Nick Kosarev <hmbanan666@hotmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmbanan666/nuxt-live-cursors"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "cursors",
    "live-cursors",
    "websocket",
    "real-time",
    "multiplayer",
    "presence"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "prepack": "nuxt-module-build build",
    "prepare": "nuxt-module-build prepare && husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "release": "bumpp -r"
  },
  "nano-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  },
  "dependencies": {
    "@nextorders/avatar": "^1.0.3",
    "@nuxt/kit": "^4.4.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/module-builder": "^1.0.0",
    "@playwright/test": "^1.58.2",
    "bumpp": "^11.0.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0",
    "nuxt": "^4.4.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  }
}
